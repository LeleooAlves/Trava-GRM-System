{
  "manifest_version": 3,
  "name": "Super Extensão GRM",
  "version": "1.0",
  "description": "Ferramenta unificada: Contador de KWs e Shopee Relevance Auto-Selector.",
  "permissions": [
    "storage",
    "notifications",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://sqe.search.shopee.io/*",
    "https://knowledgeadmin.search.shopee.io/*",
    "https://*.shopee.com.br/*",
    "https://shopee.com.br/*",
    "https://knowledge.alpha.insea.io/*",
    "https://knowledge.alpha.test.insea.io/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "Super Extensão GRM",
    "default_icon": {
      "16": "icon/icon16.png",
      "32": "icon/icon32.png",
      "48": "icon/icon48.png",
      "96": "icon/icon.png",
      "128": "icon/icon128.png"
    }
  },
  "icons": {
    "16": "icon/icon16.png",
    "32": "icon/icon32.png",
    "48": "icon/icon48.png",
    "96": "icon/icon.png",
    "128": "icon/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "supabase-bundle.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    },
    {
      "resources": [
        "*.html",
        "*.css",
        "*.js"
      ],
      "matches": [
        "https://sqe.search.shopee.io/*",
        "https://knowledgeadmin.search.shopee.io/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "all_frames": true,
      "css": [
        "content_trava.css"
      ],
      "js": [
        "content_trava.js"
      ]
    },
    {
      "matches": [
        "https://sqe.search.shopee.io/*",
        "https://knowledgeadmin.search.shopee.io/*"
      ],
      "js": [
        "content_relevancia.js"
      ]
    }
  ]
}